{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":semanticCommits",
		"mergeConfidence:all-badges"
	],
	"prCreation": "immediate",
	"rebaseWhen": "behind-base-branch",
	"dependencyDashboard": true,
	"labels": [
		"dependencies"
	],
	"github-actions": {
		"pinDigests": true
	},
	"packageRules": [
		{
			"matchCategories": [
				"docker"
			],
			"pinDigests": true
		},
		{
			"matchFileNames": [
				"frontend/**"
			],
			"labels": [
				"frontend"
			]
		},
		{
			"matchFileNames": [
				"backend/**"
			],
			"labels": [
				"backend"
			]
		},
		{
			"matchFileNames": [
				".github/**"
			],
			"labels": [
				"ci"
			]
		}
	]
}
