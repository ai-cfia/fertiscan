# Local only. Copy to .env and adjust.

# FastAPI base URL for TanStack server functions (no trailing slash).
# Example: http://localhost:8000 or http://localhost:5000
API_URL=http://localhost:8000

# Client: backend health poll interval (ms). Default 15000.
# VITE_BACKEND_HEALTH_CHECK_INTERVAL_MS=15000
# Client: list pagination default page size. Default 10.
# VITE_DEFAULT_PER_PAGE=10
# Client: max images per label (upload UI). Default 5.
# VITE_MAX_IMAGES_PER_LABEL=5

# TanStack Start encrypted session cookie (min 32 characters)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# Playwright UI login (optional; if unset, setup writes an empty storage state)
# E2E_LOGIN_EMAIL=user@example.com
# E2E_LOGIN_PASSWORD=secret
