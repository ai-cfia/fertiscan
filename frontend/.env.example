# Frontend Environment Variables

# Backend API URL
# For local development with docker-compose: http://localhost:8000
# For production: set by Kubernetes/DevOps
VITE_API_URL=http://localhost:8000

# Backend Health Check Interval (milliseconds)
# How often to poll the backend readiness endpoint
# Default: 15000 (15 seconds)
VITE_BACKEND_HEALTH_CHECK_INTERVAL_MS=15000
