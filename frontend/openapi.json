    "/api/v1/labels": {
      "get": {
        "tags": ["labels"],
        "summary": "Read Labels",
        "description": "List labels with optional filters.",
        "operationId": "labels_read_labels",
        "security": [{ "OAuth2PasswordBearer": [] }],
        "parameters": [
          {
            "name": "product_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Product type",
              "default": "fertilizer",
              "title": "Product Type"
            },
            "description": "Product type"
          },
          {
            "name": "verification_status",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                { "$ref": "#/components/schemas/VerificationStatus" },
                { "type": "null" }
              ],
              "description": "Filter by verification status",
              "title": "Verification Status"
            },
            "description": "Filter by verification status"
          },
          {
            "name": "extraction_status",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                { "$ref": "#/components/schemas/ExtractionStatus" },
                { "type": "null" }
              ],
              "description": "Filter by extraction status",
              "title": "Extraction Status"
            },
            "description": "Filter by extraction status"
          },
          {
            "name": "unlinked",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "boolean" }, { "type": "null" }],
              "description": "Filter unlinked labels only (product_id is null)",
              "title": "Unlinked"
            },
            "description": "Filter unlinked labels only (product_id is null)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Page size limit",
              "default": 50,
              "title": "Limit"
            },
            "description": "Page size limit"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Page offset",
              "default": 0,
              "title": "Offset"
            },
            "description": "Page offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LimitOffsetPage_LabelPublic_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      },
