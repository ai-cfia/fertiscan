# Environment
ENVIRONMENT=local

# Security (generate SECRET_KEY with: openssl rand -hex 32)
SECRET_KEY=changethis
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=fertiscan

# First Superuser
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Frontend
FRONTEND_HOST=http://localhost:5173

# CORS (comma-separated URLs)
BACKEND_CORS_ORIGINS=http://localhost:5173

# Email (optional - leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=FertiScan

# Email templates
EMAIL_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_TEMPLATES_DIR=app/email-templates/build

# Storage (MinIO)
STORAGE_ENDPOINT=localhost:9000
STORAGE_BUCKET_NAME=fertiscan
MINIO_ROOT_USER=changethis
MINIO_ROOT_PASSWORD=changethis

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL=gpt-4o
